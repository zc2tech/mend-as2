# PostgreSQL Database Configuration - Environment Variables
# Copy this file to .env and modify with your settings
# The application will read these environment variables at startup

# Database Server
export POSTGRES_HOST=localhost
export POSTGRES_PORT=5432

# Database Credentials
export POSTGRES_USER=as2user
export POSTGRES_PASSWORD=as2password

# Database Names
export POSTGRES_DB_CONFIG=as2_db_config
export POSTGRES_DB_RUNTIME=as2_db_runtime

# Connection Pool Settings (Optional)
export POSTGRES_POOL_MAX_SIZE=10
export POSTGRES_POOL_MIN_IDLE=2
export POSTGRES_POOL_CONN_TIMEOUT=30000
export POSTGRES_POOL_IDLE_TIMEOUT=600000
export POSTGRES_POOL_MAX_LIFETIME=1800000

# SSL Settings (Optional)
# export POSTGRES_SSL_ENABLED=true
# export POSTGRES_SSL_MODE=require
