<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <servlet>
        <servlet-name>HttpReceiver</servlet-name>
        <servlet-class>de.mendelson.comm.as2.servlet.HttpReceiver</servlet-class>
        <init-param>
            <param-name>dirAllowed</param-name>
            <param-value>false</param-value>
        </init-param>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServerState</servlet-name>
        <url-pattern>/ServerState</url-pattern>
    </servlet-mapping>    
    <servlet>
        <servlet-name>ServerState</servlet-name>
        <servlet-class>de.mendelson.comm.as2.servlet.ServerState</servlet-class>
        <init-param>
            <param-name>dirAllowed</param-name>
            <param-value>false</param-value>
        </init-param>
    </servlet>
    <servlet-mapping>
        <servlet-name>HttpReceiver</servlet-name>
        <url-pattern>/HttpReceiver</url-pattern>
    </servlet-mapping>

    <!-- REST API (Jersey) -->
    <servlet>
        <servlet-name>REST API</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>javax.ws.rs.Application</param-name>
            <param-value>de.mendelson.comm.as2.servlet.rest.RestApplication</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>REST API</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

    <!-- Admin UI Static Resources -->
    <servlet>
        <servlet-name>AdminUI</servlet-name>
        <servlet-class>de.mendelson.comm.as2.servlet.AdminUIServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUI</servlet-name>
        <url-pattern>/admin/*</url-pattern>
    </servlet-mapping>


</web-app>
