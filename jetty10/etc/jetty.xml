<?xml version="1.0"?>
<!DOCTYPE Configure PUBLIC "-//Jetty//Configure//EN" "https://www.eclipse.org/jetty/configure_10_0.dtd">

<!-- Minimal Jetty 10 Server Configuration -->
<Configure id="Server" class="org.eclipse.jetty.server.Server">

    <!-- HTTP Connector -->
    <Call name="addConnector">
        <Arg>
            <New class="org.eclipse.jetty.server.ServerConnector">
                <Arg name="server"><Ref refid="Server" /></Arg>
                <Set name="host"><Property name="jetty.http.host" default="0.0.0.0"/></Set>
                <Set name="port"><Property name="jetty.http.port" default="8080"/></Set>
                <Set name="idleTimeout"><Property name="jetty.http.idleTimeout" default="30000"/></Set>
            </New>
        </Arg>
    </Call>

    <!-- HTTPS Connector (optional, requires TLS configuration) -->
    <!-- Uncomment and configure if HTTPS is needed -->
