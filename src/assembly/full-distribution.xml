<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>full</id>
    <formats>
        <format>tar.gz</format>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>mend-as2-${project.version}-full</baseDirectory>

    <fileSets>
        <!-- Main JAR file -->
        <fileSet>
            <directory>${project.build.directory}</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>mend-as2-${project.version}-full.jar</include>
            </includes>
        </fileSet>

        <!-- Configuration files -->
        <fileSet>
            <directory>config</directory>
            <outputDirectory>config</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
            <excludes>
                <exclude>**/*.db</exclude>
                <exclude>**/*.lck</exclude>
            </excludes>
        </fileSet>

        <!-- Documentation -->
        <fileSet>
            <directory>${project.basedir}</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>README.md</include>
                <include>INSTALL.md</include>
            </includes>
        </fileSet>

        <!-- Build profiles documentation -->
        <fileSet>
            <directory>md-memo</directory>
            <outputDirectory>docs</outputDirectory>
            <includes>
                <include>BUILD_PROFILES.md</include>
            </includes>
        </fileSet>

        <!-- License -->
        <fileSet>
            <directory>license</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>LICENSE.gpl.txt</include>
            </includes>
        </fileSet>

        <!-- SQL scripts (for reference/manual execution if needed) -->
        <fileSet>
            <directory>src/main/resources/sqlscript</directory>
            <outputDirectory>sqlscript</outputDirectory>
            <includes>
                <include>**/*.sql</include>
            </includes>
        </fileSet>

        <!-- Startup scripts -->
        <fileSet>
            <directory>src/assembly/scripts</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>start.sh</include>
                <include>start-headless.sh</include>
                <include>start.bat</include>
                <include>start-headless.bat</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>

        <!-- Create empty directories -->
        <fileSet>
            <directory>src/assembly/empty</directory>
            <outputDirectory>log</outputDirectory>
            <excludes>
                <exclude>**/*</exclude>
            </excludes>
        </fileSet>
        <fileSet>
            <directory>src/assembly/empty</directory>
            <outputDirectory>messages</outputDirectory>
            <excludes>
                <exclude>**/*</exclude>
            </excludes>
        </fileSet>
        <fileSet>
            <directory>src/assembly/empty</directory>
            <outputDirectory>data</outputDirectory>
            <excludes>
                <exclude>**/*</exclude>
            </excludes>
        </fileSet>
    </fileSets>
</assembly>
